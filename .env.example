# TurfMate frontend (copy to .env.local for dev, set in Vercel/Netlify for prod)

# API (Express backend)
VITE_API_URL=http://localhost:3001/api
VITE_SOCKET_URL=http://localhost:3001

# Public app URL (used for split invite links in production)
VITE_APP_URL=http://localhost:3000

# Demo OTP shortcuts (9876543210 / 1234). Set false for pilot/production.
VITE_DEMO_MODE=true

# WhatsApp support line for pilot (country code + number, e.g. 919876543210)
VITE_SUPPORT_WHATSAPP=

# Razorpay (test key for pilot, live key for production)
VITE_RAZORPAY_KEY_ID=
