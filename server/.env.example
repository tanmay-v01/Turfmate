PORT=3001
NODE_ENV=development

# Comma-separated allowed origins (no spaces). Production example:
# CORS_ORIGIN=https://app.turfmate.in,https://www.turfmate.in
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# SQLite path (local dev when DATABASE_URL unset)
SQLITE_PATH=./turfmate.db

# PostgreSQL (Railway / Supabase / Neon) — Phase 1+
DATABASE_URL=

# Phase 1 auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
DEMO_MODE=true
SEED_ON_START=false
SEED_PILOT_ON_START=false
MIGRATE_ON_START=false

# Razorpay (server-side secrets — never expose to frontend)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# OTP provider (MSG91) — set both for live SMS OTP
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# JWT for session tokens (generate a long random string)
JWT_SECRET=change-me-to-a-long-random-string

# Public app URL for split invite links in push notifications
APP_URL=http://localhost:3000

# Firebase Cloud Messaging server key (optional — inbox still works without it)
FCM_SERVER_KEY=
