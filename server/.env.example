PORT=3001
NODE_ENV=development

# Comma-separated allowed origins (no spaces). Production example:
# CORS_ORIGIN=https://app.turfmate.in,https://www.turfmate.in
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# SQLite path (pilot). Production: migrate to DATABASE_URL (Postgres)
SQLITE_PATH=./turfmate.db

# Razorpay (server-side secrets — never expose to frontend)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# OTP provider (MSG91 example)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# JWT for session tokens (generate a long random string)
JWT_SECRET=
