{
  "name": "turfmate",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "npm --prefix server run start",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "dev:server": "npm --prefix server run dev",
    "verify:pilot": "npm --prefix server run verify:pilot",
    "pilot:smoke": "npm --prefix server run pilot:smoke",
    "seed:pilot": "npm --prefix server run seed:pilot",
    "load-test:locks": "node scripts/load-test-locks.mjs",
    "security:audit": "npm --prefix server run security:audit",
    "generate:pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "build:android": "npm run build && npx cap sync android",
    "open:android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.7",
    "postcss": "^8.4.38",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "vite-plugin-pwa": "^1.3.0"
  }
}
